<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.asmvik.yabai</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/yabai</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Volumes/m2/Usuarios/.pi/agent/bin:/Volumes/m2/Usuarios/.cargo/bin:/Volumes/m2/Usuarios/go/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/Volumes/m2/Usuarios/.local/bin:/Volumes/m2/Usuarios/.opencode/bin:/Volumes/m2/Usuarios/.volta/bin:/Volumes/m2/Usuarios/.bun/bin:/Volumes/m2/Usuarios/.nix-profile/bin:/nix/var/nix/profiles/default/bin:/usr/local/bin:/Volumes/m2/Usuarios/.config:/Volumes/m2/Usuarios/.cargo/bin:/usr/local/lib/node_modules:/usr/local/bin:/System/Cryptexes/App/usr/bin:/usr/bin:/bin:/usr/sbin:/sbin:/var/run/com.apple.security.cryptexd/codex.system/bootstrap/usr/local/bin:/var/run/com.apple.security.cryptexd/codex.system/bootstrap/usr/bin:/var/run/com.apple.security.cryptexd/codex.system/bootstrap/usr/appleinternal/bin:/pkg/env/global/bin:/Library/Apple/usr/bin:/Volumes/m2/Usuarios/go/bin:/Volumes/m2/Usuarios/.local/bin:/Volumes/m2/Usuarios/.opencode/bin:/Volumes/m2/Usuarios/.volta/bin:/Volumes/m2/Usuarios/.bun/bin:/Volumes/m2/Usuarios/.nix-profile/bin:/nix/var/nix/profiles/default/bin:/Volumes/m2/Usuarios/.config:/Volumes/m2/Usuarios/.cargo/bin:/usr/local/lib/node_modules:/Applications/kitty.app/Contents/MacOS</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
 	     <false/>
 	     <key>Crashed</key>
 	     <true/>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/yabai_saul.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/yabai_saul.err.log</string>
    <key>ProcessType</key>
    <string>Interactive</string>
    <key>Nice</key>
    <integer>-20</integer>
</dict>
</plist>